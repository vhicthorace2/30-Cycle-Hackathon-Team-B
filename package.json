{
  "name": "CIAP",
  "version": "0.0.1",
  "description": "Creative Influence and Analytics Platform for SMEs and creators ",
  "author": "group2",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prebuild": "rimraf dist",
    "prepare": "husky",
    "clean": "rimraf dist && rimraf node_modules && pnpm store prune",
    "build": "nest build application --config nest-cli.json",
    "build:dev": "nest build application --config nest-cli.json --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "deadcode": "ts-prune --project tsconfig.json",
    "start": "nest start application --config nest-cli.json",
    "start:dev": "nest start --watch --config nest-cli.json",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint .",
    "lint-fix": "eslint --fix",
    "lint:staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "test": "cross-env TZ=UTC jest --config ./test/jest-e2e.json --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:format": "drizzle-kit format",
    "db:seed": "ts-node -P tsconfig.seed.json -r tsconfig-paths/register src/database/seeds/seed.ts",
    "db:seed:prod": "node dist/database/seeds/seed",
    "package:check": "npx npm-check-updates -i",
    "package:upgrade": "npx npm-check-updates -u "
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@neondatabase/serverless": "^1.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "bullmq": "^5.74.1",
    "bytes": "^3.1.2",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.6.0",
    "nestjs-pino": "^4.6.1",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.8.0",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^4.6.3",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.39",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-oauth2": "^1.8.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix"
    ],
    "*.{json,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "node": ">= 24.11.0",
    "pnpm": ">= 10.25.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@database/(.*)$": "<rootDir>/database/$1",
      "^@types/(.*)$": "<rootDir>/types/$1",
      "^@bases/(.*)$": "<rootDir>/common/bases/$1",
      "^@decorators/(.*)$": "<rootDir>/common/decorators/$1",
      "^@exceptions/(.*)$": "<rootDir>/common/exceptions/$1",
      "^@filters/(.*)$": "<rootDir>/common/filters/$1",
      "^@guards/(.*)$": "<rootDir>/common/guards/$1",
      "^@interceptors/(.*)$": "<rootDir>/common/interceptors/$1",
      "^@middlewares/(.*)$": "<rootDir>/common/middlewares/$1",
      "^@pipes/(.*)$": "<rootDir>/common/pipes/$1",
      "^@validators/(.*)$": "<rootDir>/common/validators/$1",
      "^@utils/(.*)$": "<rootDir>/common/utils/$1",
      "^@interfaces/(.*)$": "<rootDir>/common/interfaces/$1",
      "^@constants/(.*)$": "<rootDir>/common/constants/$1",
      "^@factories/(.*)$": "<rootDir>/common/factories/$1",
      "^@migrations/(.*)$": "<rootDir>/database/drizzle/migrations/$1",
      "^@generated/(.*)$": "<rootDir>/generated/$1",
      "^@test/(.*)$": "<rootDir>/../test/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
