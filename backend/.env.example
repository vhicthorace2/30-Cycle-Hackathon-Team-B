################################################################################
# ENVIRONMENT CONFIGURATION - Development
# This file is loaded by dotenv. For production, use .env.production
################################################################################

# Node Environment (development | staging | production)
NODE_ENV=development

################################################################################
# DATABASE CONFIGURATION
################################################################################
DATABASE_URL=postgresql://ciap:ciap_dev_password@postgres:5432/ciap?sslmode=disable

################################################################################
# CONTAINER / DOCKER-COMPOSE CONFIGURATION
################################################################################
APP_PORT=3000
POSTGRES_DB=ciap
POSTGRES_USER=ciap
POSTGRES_PASSWORD=ciap_dev_password
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
# For local development (without password): redis://localhost:6379
# For Docker Compose: redis://:redis_dev_password@redis:6379
# For managed Redis with TLS: rediss://default:password@host:6380/0
REDIS_URL=redis://:redis_dev_password@redis:6379
