UPLOAD_DIR=./uploads

################################################################################
# THIRD-PARTY SERVICES (Optional - preseed for future integrations)
################################################################################
# Email Service
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com


# OAuth2 Providers (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/auth/socials/google/login/callback
GOOGLE_YOUTUBE_REDIRECT_URI=http://localhost:3000/ingestion/youtube/oauth2/callback
# Legacy fallback for older OAuth clients
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/socials/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

################################################################################
# SWAGGER METADATA (Optional)
################################################################################
APP_NAME=CIAP Backend
APP_DESCRIPTION=NestJS API with Drizzle ORM and PostgreSQL
APP_VERSION=1.0.0
APP_SUPPORT_NAME=CIAP API Team
APP_SUPPORT_URL=
APP_SUPPORT_EMAIL=
APP_LICENSE_NAME=UNLICENSED
APP_LICENSE_URL=

################################################################################
# MONITORING & OBSERVABILITY (Optional - for future use)
################################################################################
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1
