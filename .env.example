################################################################################
# ENVIRONMENT CONFIGURATION - Development
# This file is loaded by dotenv. For production, use .env.production
################################################################################

# Node Environment (development | staging | production)
NODE_ENV=development

################################################################################
# DATABASE CONFIGURATION
################################################################################
DATABASE_URL=postgresql://ciap:ciap_dev_password@postgres:5432/ciap?sslmode=disable

################################################################################
# CONTAINER / DOCKER-COMPOSE CONFIGURATION
################################################################################
APP_PORT=3000
POSTGRES_DB=ciap
POSTGRES_USER=ciap
POSTGRES_PASSWORD=ciap_dev_password
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
# For local development (without password): redis://localhost:6379
# For Docker Compose: redis://:redis_dev_password@redis:6379
REDIS_URL=redis://:redis_dev_password@redis:6379
BULLMQ_PREFIX=bull
BULLBOARD_PORT=3100
BULLBOARD_ROOT_PATH=/
BULLBOARD_REDIS_DB=0
BULLBOARD_USER_LOGIN=admin
BULLBOARD_USER_PASSWORD=admin123

################################################################################
# SERVER CONFIGURATION
################################################################################
PORT=3000
HOST=localhost

################################################################################
# LOGGING CONFIGURATION
# Levels: error, warn, log, debug, verbose
################################################################################
LOG_ENABLED=true
LOG_BACKEND=pino
LOG_HTTP_ENABLED=true
LOG_HTTP_MODE=errors
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/ciap.log
LOG_FILE_LEVEL=info
LOG_FILE_SIZE=50m
LOG_FILE_FREQUENCY=daily

################################################################################
# CORS CONFIGURATION
################################################################################
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

################################################################################
# API CONFIGURATION
################################################################################
API_VERSION=v1
API_PREFIX=/api

################################################################################
# AUTHENTICATION & SECURITY
################################################################################
BCRYPT_ROUNDS=10
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_ES256_PRIVATE_KEY\n-----END PRIVATE KEY-----\n
JWT_ACCESS_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_ES256_PUBLIC_KEY\n-----END PUBLIC KEY-----\n
JWT_REFRESH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_ES512_PRIVATE_KEY\n-----END PRIVATE KEY-----\n
JWT_REFRESH_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_ES512_PUBLIC_KEY\n-----END PUBLIC KEY-----\n
ADMIN_SIGNUP_KEY=replace-with-strong-admin-signup-key

################################################################################
# RATE LIMITING (Optional - for future use)
################################################################################
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

################################################################################
# CACHE CONFIGURATION (Optional - for future use)
################################################################################
CACHE_TTL=300
CACHE_MAX_SIZE=100
CACHE_DEFAULT_TTL_HOURS=1

################################################################################
# FILE UPLOAD CONFIGURATION (Optional - for future use)
################################################################################
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

################################################################################
# THIRD-PARTY SERVICES (Optional - preseed for future integrations)
################################################################################
# Email Service
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com


# OAuth2 Providers (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/auth/socials/google/login/callback
GOOGLE_YOUTUBE_REDIRECT_URI=http://localhost:3000/ingestion/youtube/oauth2/callback
# Legacy fallback for older OAuth clients
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/socials/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

################################################################################
# SWAGGER METADATA (Optional)
################################################################################
APP_NAME=CIAP Backend
APP_DESCRIPTION=NestJS API with Drizzle ORM and PostgreSQL
APP_VERSION=1.0.0
APP_SUPPORT_NAME=CIAP API Team
APP_SUPPORT_URL=
APP_SUPPORT_EMAIL=
APP_LICENSE_NAME=UNLICENSED
APP_LICENSE_URL=

################################################################################
# MONITORING & OBSERVABILITY (Optional - for future use)
################################################################################
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1
